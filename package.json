{
  "name": "cfb-dynasty-bot",
  "version": "0.1.0",
  "description": "Companion bot foundation for EA Sports College Football online dynasties.",
  "type": "module",
  "scripts": {
    "start": "node src/cli.js",
    "server": "node src/server.js",
    "register": "node src/register-commands.js",
    "ea:auth-url": "node src/discovery/ea-auth.js auth-url",
    "ea:exchange": "node src/discovery/ea-auth.js exchange",
    "ea:whoami": "node src/discovery/ea-auth.js whoami",
    "ea:probe": "node src/discovery/probe-candidates.js",
    "ea:team-builder": "node src/discovery/team-builder-config.js",
    "redzone:once": "node src/redzone-watcher.js",
    "redzone:watch": "node src/redzone-watcher.js --watch",
    "redzone:server": "node src/redzone-watcher.js --server",
    "redzone:worker:deploy": "npx wrangler deploy --config wrangler.toml",
    "redzone:worker:dev": "npx wrangler dev --config wrangler.toml",
    "smoke": "node src/cli.js seed --force && node src/cli.js standings && node src/cli.js matchups && node src/cli.js result g001 31 24 && node src/cli.js advance"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {}
}
